# Plantilla de variables de entorno del backend.
# Copia este archivo como .env y rellena los valores reales.
# El .env real NUNCA se sube al repo (está en .gitignore).

# Ruta de la base de datos SQLite
DATABASE_URL=sqlite:///./kaizen.db

# Origen permitido para CORS (la URL del frontend en desarrollo)
FRONTEND_URL=http://localhost:5173
